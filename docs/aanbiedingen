    .page { max-width: 1100px; margin: 0 auto; padding: 3rem 2rem 6rem; }

    .page-header { margin-bottom: 3rem; }
    .breadcrumb { font-size: 0.78rem; color: var(--text-muted); margin-bottom: 1.5rem; }
